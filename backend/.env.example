# Backend environment variables. Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit real secrets.

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Debug mode. Use True for local development, False in production.
DEBUG=True

# Gemini API key — powers the AI assistant chat. Get a free key at
# https://aistudio.google.com/apikey  Leave blank to keep AI disabled (graceful 503).
GEMINI_API_KEY=

# Anthropic key — legacy/optional (provider was switched to Gemini).
ANTHROPIC_API_KEY=
