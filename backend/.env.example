# Backend environment variables. Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit real secrets.

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Debug mode. Use True for local development, False in production.
DEBUG=True

# Gemini API key — powers the AI assistant chat. Get a free key at
# https://aistudio.google.com/apikey  Leave blank to keep AI disabled (graceful 503).
GEMINI_API_KEY=

# Anthropic key — legacy/optional (provider was switched to Gemini).
ANTHROPIC_API_KEY=

# ---- Production (leave blank for local dev) ----
# Comma-separated hosts Django will serve (e.g. your Render domain).
ALLOWED_HOSTS=
# Neon Postgres connection string. If unset, falls back to local SQLite.
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=
# SPA origin(s) allowed to call the API (e.g. https://yourapp.vercel.app).
CORS_ALLOWED_ORIGINS=
# Origins trusted for cross-site POSTs (same Vercel URL, scheme included).
CSRF_TRUSTED_ORIGINS=
# Public URL of the frontend — used to build the email verification link.
FRONTEND_URL=

# ---- OAuth (Google + GitHub) — account creation is social-login only ----
# Client IDs are public; secrets stay backend-only. Redirect/callback URLs must
# match FRONTEND_URL/auth/callback/<provider>. The frontend also needs the IDs
# (VITE_GOOGLE_CLIENT_ID / VITE_GITHUB_CLIENT_ID).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Email (SMTP) — optional now (no verification; only password reset) ----
# If EMAIL_HOST is set, Django uses real SMTP; otherwise mail prints to the console.
# Brevo example: EMAIL_HOST=smtp-relay.brevo.com, EMAIL_HOST_USER=<your @smtp-brevo.com
# login>, EMAIL_HOST_PASSWORD=<SMTP key>, DEFAULT_FROM_EMAIL="Name <verified@sender.com>".
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Optional throttle overrides (defaults: anon 120/min, user 600/min, ai 12/min + 120/day).
THROTTLE_ANON=
THROTTLE_USER=
THROTTLE_AI_BURST=
THROTTLE_AI_DAILY=

# Lesson schedule + streaks (Phase 15). Defaults shown.
# Weekdays new lessons unlock (Mon=0 … Sun=6); default Mon/Wed/Fri.
LESSON_UNLOCK_WEEKDAYS=0,2,4
STREAK_INITIAL_FREEZE_TOKENS=2
STREAK_FREEZE_EARN_DAYS=14
STREAK_FREEZE_MAX=5

# Recitation v2 cost control (Phase 16). Defaults shown.
RECITATION_DAILY_CAP=5
RECITATION_MAX_AUDIO_SECONDS=120
RECITATION_MAX_AUDIO_MB=10

# Video suggestions (Phase 17): minimum CEFR level at which they unlock.
VIDEO_UNLOCK_MIN_LEVEL=B1

# Cloudinary (profile picture uploads). Leave blank to disable avatar uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
