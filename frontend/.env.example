# Frontend environment variables. Copy to `.env.local` (git-ignored) to override.

# Base URL for the Django API. Defaults to http://localhost:8000/api if unset.
VITE_API_BASE_URL=http://localhost:8000/api

# OAuth client IDs (public — safe in the frontend; the secrets live on the
# backend). Required for the Google/GitHub sign-in buttons to work.
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
